# Secrets — env.json is auto-generated from the versioned env.json.template
# (see android/app/build.gradle.kts) and holds the real keys, so it stays out of
# git. Fill in your Supabase keys in env.json; never put real keys in the template.
*.env
env.json
.dart-define*.json
*.keystore
*.jks
